.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: var(--bg-color-primary, #F3F3F3);
  color: var(--text-color-primary, #333333);
}

/* 导航栏 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 100;
  display: flex;
  align-items: center;
  background-color: var(--bg-color-primary, #F3F3F3);
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.back-btn {
  width: 80rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-title {
  flex: 1;
  text-align: center;
  font-weight: bold;
  font-size: 32rpx;
  padding-right: 80rpx; /* 平衡 back-btn */
}

/* 滚动区 */
.scroll-content {
  flex: 1;
  height: 100%;
}

/* Hero Section */
.hero-section {
  position: relative;
  width: 100%;
  height: 600rpx;
  background-color: #DDDDDD; /* fallback */
  overflow: hidden;
}
.portrait-container {
  width: 100%;
  height: 100%;
}
.portrait-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #999;
  background-color: #EAEAEA;
}
.toggle-btn {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  background-color: rgba(0,0,0,0.5);
  color: #FFF;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

/* 信息覆盖层 */
.info-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 30rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0) 100%);
  color: #FFFFFF;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}
.stars {
  color: #E2D794; /* 偏白金色的星级 */
  font-size: 32rpx;
  letter-spacing: 4rpx;
  margin-bottom: 4rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.5);
}
.en-name {
  font-size: 24rpx;
  opacity: 0.9;
  text-transform: uppercase;
  margin-bottom: 2rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.5);
}
.cn-name {
  font-size: 56rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 6rpx rgba(0,0,0,0.5);
}

/* 职业与标签布局 */
.class-and-tags-layout {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: 16rpx;
}
/* 大方形职业图标 */
.main-class-icon {
  width: 100rpx;
  height: 100rpx;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.8);
}
.icon-text {
  font-size: 26rpx;
  font-weight: bold;
  color: #FFF;
}
/* 右侧内容列 */
.tags-column {
  display: flex;
  flex-direction: column;
  justify-content: space-between; /* 上下对齐到大图标的高度 */
  padding: 2rpx 0;
}
/* 行布局 */
.tags-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}
/* 子职业组合标签 */
.subclass-badge {
  display: flex;
  flex-direction: row;
  background-color: rgba(80, 80, 80, 0.9);
  align-items: stretch;
}
.subclass-icon-square {
  background-color: rgba(120, 120, 120, 0.9);
  padding: 4rpx 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}
.subclass-name {
  padding: 4rpx 12rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
}
/* 部署位与其他标签 */
.pos-tag, .trait-tags {
  background-color: rgba(50, 50, 50, 0.9);
  padding: 4rpx 16rpx;
  font-size: 24rpx;
}

/* 模块标题 */

.section {
  padding: 30rpx;
}
.h2-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  color: #333333;
  border-left: 8rpx solid var(--accent-color, #D32F2F);
  padding-left: 16rpx;
}
.h3-title {
  font-size: 30rpx;
  font-weight: bold;
  margin: 30rpx 0 16rpx 0;
  color: #444444;
}
.h4-title {
  font-size: 28rpx;
  font-weight: bold;
  margin: 20rpx 0 10rpx 0;
  color: #555555;
}
.h5-title {
  font-size: 26rpx;
  font-weight: bold;
  margin: 16rpx 0 8rpx 0;
  color: #666666;
}

/* Rank Board */
.rank-board {
  display: flex;
  justify-content: space-around;
  background-color: #FFFFFF;
  padding: 30rpx 0;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}
.rank-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.rank-label {
  font-size: 24rpx;
  color: #666666;
}
.rank-value {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--accent-color, #D32F2F);
}

/* Flex Table System */
.flex-table {
  display: flex;
  flex-direction: column;
  border: 2rpx solid #999999;
  margin-bottom: 20rpx;
  font-size: 24rpx;
  background-color: #FFFFFF;
}
.ft-row {
  display: flex;
  flex-direction: row;
  border-bottom: 2rpx solid #BBBBBB;
}
.ft-row:last-child {
  border-bottom: none;
}
.ft-cell {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 8rpx;
  border-right: 2rpx solid #BBBBBB;
  text-align: center;
}
.ft-cell:last-child {
  border-right: none;
}
.bg-60 {
  background-color: rgba(193, 198, 214, 0.6);
  font-weight: bold;
}
.bg-20 {
  background-color: rgba(193, 198, 214, 0.2);
}
.align-left {
  justify-content: flex-start !important;
  text-align: left !important;
}
.center-content {
  justify-content: center !important;
  text-align: center !important;
}

/* Trait Table 特殊布局 */

/* --- Hero Info Table --- */
.hero-info-table {
  display: flex;
  flex-direction: column;
  width: 100%;
}
.hero-row {
  display: flex;
  flex-direction: row;
  width: 100%;
  margin-bottom: 8rpx;
}
.hero-cell {
  display: flex;
}
.col-span-3, .col-span-2 {
  width: 100%;
}
.align-left {
  justify-content: flex-start;
}
.align-center {
  justify-content: center;
}

/* 文本样式 */
.stars {
  color: #FFD700;
  font-size: 32rpx;
  letter-spacing: 4rpx;
}
.en-name {
  font-size: 24rpx;
  opacity: 0.8;
  text-transform: uppercase;
}
.cn-name {
  font-size: 48rpx;
  font-weight: bold;
}

/* 职业与标签容器 */
.class-row {
  margin-top: 8rpx;
  margin-bottom: 0;
  align-items: stretch;
}
.main-class-cell {
  margin-right: 16rpx;
}
.main-class-icon {
  width: 90rpx;
  height: 90rpx;
  background-color: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}
.icon-text {
  font-size: 24rpx;
  font-weight: bold;
}

/* Tags 右侧容器 */
.tags-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.tags-top-row {
  justify-content: flex-start;
  gap: 16rpx;
  margin-bottom: 0;
}
.tags-bottom-row {
  justify-content: center;
  margin-bottom: 0;
}

/* 子组件样式 */
.subclass-badge {
  display: flex;
  flex-direction: row;
  background-color: rgba(0, 0, 0, 0.4);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  align-items: stretch;
}
.subclass-icon-square {
  background-color: rgba(255, 255, 255, 0.2);
  padding: 4rpx 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}
.subclass-name {
  padding: 4rpx 12rpx;
  font-size: 22rpx;
  display: flex;
  align-items: center;
}

.pos-tag, .trait-tags {
  background-color: rgba(0, 0, 0, 0.4);
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  font-size: 22rpx;
}
/* ----------------------- */
