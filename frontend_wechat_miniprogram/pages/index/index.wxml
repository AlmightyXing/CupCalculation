<view class="container">
  
  <view class="back-btn" style="top: {{statusBarHeight}}px;" bindtap="exitMiniProgram">
    <icon type="cancel" size="24" color="#333333"></icon>
  </view>

  <view class="custom-header" style="margin-top: {{statusBarHeight + 44}}px;">
    <image class="header-bg" src="../../image/Background.png" mode="widthFix"></image>
    
    <view class="header-content">
      <view class="title-container">
        <image class="header-title" src="../../image/Text_Title.png" mode="heightFix"></image>
      </view>
      
      <view class="search-bar" bindtap="goToSearch">
        <icon type="search" size="18" color="#666666"></icon>
        <text class="search-text">搜索干员名或外号(如42)</text>
      </view>
      
      <view class="tabs-container">
        <view class="tab-btn {{currentTab === 'total' ? 'active' : ''}}" bindtap="switchTab" data-tab="total">
          <image class="tab-icon" src="../../image/Navi_Bar_Cup.png" mode="aspectFit"></image>
        </view>
        <view class="tab-btn {{currentTab === 'idle' ? 'active' : ''}}" bindtap="switchTab" data-tab="idle">
          <image class="tab-icon" src="../../image/Navi_Bar_Auto.png" mode="aspectFit"></image>
        </view>
        <view class="tab-btn {{currentTab === 'burst' ? 'active' : ''}}" bindtap="switchTab" data-tab="burst">
          <image class="tab-icon" src="../../image/Navi_Bar_Manual.png" mode="aspectFit"></image>
        </view>
        <view class="tab-btn" bindtap="goToSandbox">
          <view style="width: 60rpx; height: 60rpx; background-color: #888888; border-radius: 12rpx;"></view>
        </view>
      </view>
    </view>
  </view>

  <view class="table-header-bar">
    <text class="title">{{currentTabName}}</text>
    
    <picker bindchange="onEnemyChange" value="{{enemyIndex}}" range="{{enemyOptions}}">
      <view class="picker-btn">
        <text>{{enemyOptions[enemyIndex]}}</text>
        <text class="dropdown-icon">▼</text>
      </view>
    </picker>
  </view>

  <!-- 表格表头 -->
  <view class="table-header">
    <block wx:if="{{currentTab === 'total'}}">
      <view class="th cup-col">Cup</view>
      <view class="th rank-col">Rank</view>
      <view class="th avatar-col">头像</view>
      <view class="th name-col">干员名称</view>
      <view class="th prof-col">职业</view>
      <view class="th rank-col">挂机</view>
      <view class="th rank-col">决战</view>
    </block>
    <block wx:else>
      <view class="th rank-col">Rank</view>
      <view class="th avatar-col">头像</view>
      <view class="th name-col">干员名称</view>
      <view class="th prof-col">职业</view>
      <view class="th num-col">DPS</view>
      <view class="th num-col">总伤</view>
    </block>
  </view>

  <scroll-view scroll-y class="content-scroll">
    <view class="list-container">
      
      <!-- 总杯榜 合并视图 -->
      <block wx:if="{{currentTab === 'total'}}">
        <block wx:for="{{groupedOperators}}" wx:key="cup_level">
          <view class="cup-group">
            <view class="group-cup-col">
              <text class="cup-text">{{item.cup_level}}</text>
            </view>
            <view class="group-rows">
              <block wx:for="{{item.list}}" wx:for-item="op" wx:key="rank">
                <operator-card item="{{op}}" mode="total" isLast="{{index === item.list.length - 1}}"></operator-card>
              </block>
            </view>
          </view>
        </block>
      </block>
      
      <!-- 挂机/决战榜 扁平视图 -->
      <block wx:else>
        <block wx:for="{{operators}}" wx:key="rank">
          <operator-card item="{{item}}" mode="skill"></operator-card>
        </block>
      </block>
      
      <view class="damage-note">
        <view class="note-title">* 伤害计算说明</view>
        <view class="note-item">- 当前敌人抗性基准: {{enemyOptions[enemyIndex]}}</view>
        <view class="note-item">- 仅计算理论最大值，不考虑实战中的实际覆盖率。</view>
        <view class="note-item">- 计算公式: 理论DPS = (攻击力 - 护甲) × 攻速倍率 (不低于保底伤害)</view>
      </view>

    </view>
  </scroll-view>

</view>
